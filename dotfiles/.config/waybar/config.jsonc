[
{
   "id": "bar-0",
   "name": "bar-niri",
   "layer": "top",
   "mode": "dock",
   "height": 38,
   "margin": 0,
   "spacing": 1,
   "include": [
      "$HOME/.config/waybar/modules.jsonc"
   ],
   "modules-left": [
      "custom/launcher",
      "niri/workspaces",
      "niri/window"
   ],
   "modules-center": [
      "clock"
   ],
   "modules-right": [
      "network",
      "cpu",
      "memory",
      "pulseaudio",
      "inhibitor",
      "tray"
   ]
}
]
