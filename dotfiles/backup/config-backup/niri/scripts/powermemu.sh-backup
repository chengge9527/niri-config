#!/bin/bash

# 使用 fuzzel 渲染选项（修正了 -p 参数）
SELECTION=$(echo -e "          取消\n          确认" | fuzzel --dmenu --prompt="     确定要退出桌面吗？" --lines 2 --width 25)

case "$SELECTION" in
    "确认退出 (含 Waydroid)")
        waydroid session stop
        niri msg action quit --skip-confirmation
        ;;
    *)
        # 选择了取消或者直接按了 Esc，不执行任何操作优雅退出
        exit 0
        ;;
esac
